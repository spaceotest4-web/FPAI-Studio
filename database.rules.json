{
  "rules": {
    "messages": {
      ".read": true,
      "$room": {
        ".read": true,
        "$messageId": {
          ".write": "!data.exists()",
          ".validate": "newData.hasChildren(['userId','text','timestamp']) && newData.child('text').isString() && newData.child('text').val().length <= 500 && newData.child('userId').isString() && newData.child('userId').val().length <= 40"
        }
      }
    },
    "presence": {
      ".read": true,
      "$uid": {
        ".write": true,
        ".validate": "newData.hasChildren(['lastSeen'])"
      }
    },
    "custom_rooms": {
      ".read": true,
      "$roomId": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['name'])"
      }
    },
    "gallery": {
      ".read": true,
      "$id": {
        ".write": "newData.exists()",
        ".validate": "newData.hasChildren(['prompt','url','timestamp']) && newData.child('url').isString() && newData.child('url').val().length <= 2000 && newData.child('prompt').isString() && newData.child('prompt').val().length <= 1000 && newData.child('timestamp').isNumber()"
      }
    }
  }
}
